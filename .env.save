# Vercel AI Gateway key — required.
# Get it from https://vercel.com/dashboard (AI Gateway tab → create key).
AI_GATEWAY_API_KEY= 

# Optional. Any Vercel AI Gateway "provider/model" string.
# Examples:
#   anthropic/claude-sonnet-4-6   (default)
#   anthropic/claude-opus-4-7
#   anthropic/claude-haiku-4-5
#   openai/gpt-4o
#   openai/gpt-4o-mini
# DEFAULT_MODEL=anthropic/claude-sonnet-4-6
